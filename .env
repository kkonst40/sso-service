# ENV
ENV=dev
REST_PORT=8081
GRPC_PORT=50051

# DB
DB_HOST=ssodb
DB_PORT=5432
POSTGRES_USER=app_user
POSTGRES_PASSWORD=app_password
POSTGRES_DB=app_db

# Kafka
KAFKA_HOST=kafka
KAFKA_PORT=9092

CRED_LOGIN_CHARS="ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz1234567890_"
CRED_MAX_LOGIN_LENGTH=20
CRED_MIN_LOGIN_LENGTH=5
CRED_PASSWORD_CHARS="ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz1234567890_!@#$%^&*()"
CRED_MAX_PASSWORD_LENGTH=32
CRED_MIN_PASSWORD_LENGTH=8